      "version": "0.2.0",
      "configurations": [
            {
                  "name": "Cortex Debug (OpenOCD)",
                  "cwd": "${workspaceFolder}",
                  "executable": "${workspaceFolder}/build_CH32x035_Sample/CH32x035_Sample.elf",
                  "configFiles": [
                        "${workspaceFolder}/tools/MRS_Toolchain_Linux_x64_V1.92/OpenOCD/bin/wch-riscv.cfg"
                  ],
                  "request": "launch",
                  "type": "cortex-debug",
                  "runToEntryPoint": "main",
                  "gdbPath": "${workspaceFolder}/tools/MRS_Toolchain_Linux_x64_V1.92/RISC-V_Embedded_GCC12/bin/riscv-none-elf-gdb",
                  "servertype": "openocd",
                  "serverpath": "${workspaceFolder}/tools/MRS_Toolchain_Linux_x64_V1.92/OpenOCD/bin/openocd",
                  "liveWatch": true,
                  "showDevDebugOutput": true
            }
      ]
}
